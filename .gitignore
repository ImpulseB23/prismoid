# Rust
**/target/
**/*.rs.bk

# Go
**/bin/
# Rust crates use `src/bin/` for additional binary targets — un-ignore
# those so they stay tracked even when under the **/bin/ wildcard.
!**/src/bin/
!**/src/bin/**

# Node
**/node_modules/
**/dist/

# Tauri
**/gen/

# Environment
.env
.env.*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo

# Vinxi / SolidStart
**/.vinxi/
**/.output/

# Wrangler
**/.wrangler/

# Build artifacts
*.exe
*.dll
*.so
*.dylib

# Test coverage
**/coverage/
*.lcov

# Logs
*.log
