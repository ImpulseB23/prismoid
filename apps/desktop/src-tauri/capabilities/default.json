{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Prismoid",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://www.twitch.tv/*" },
        { "url": "https://id.twitch.tv/*" }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
